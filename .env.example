APP_NAME="Guised Up Feed"
APP_ENV=local
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Docker host ports. If API_HOST_PORT changes, update APP_URL and
# EXPO_PUBLIC_API_URL to the same host port.
API_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
EMBEDDING_HOST_PORT=18080

LOG_CHANNEL=stack
LOG_LEVEL=debug
QUEUE_CONNECTION=sync

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=guised_up
DB_USERNAME=guised_up
DB_PASSWORD=guised_up

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:19006,127.0.0.1

FEED_EMBEDDING_DIMENSIONS=384
FEED_EMBEDDING_MODEL=hash-embedding-v1
FEED_EMBEDDING_SERVICE_URL=http://embedding:8080
FEED_EMBEDDING_SERVICE_TOKEN=local-embedding-service-token
FEED_EMBEDDING_TIMEOUT_SECONDS=3
FEED_ALLOW_HASH_EMBEDDING_FALLBACK=true
FEED_EMBEDDING_QUEUE=embeddings
FEED_CACHE_PROFILES=true
FEED_VIEWER_INTEREST_CACHE_SECONDS=300
FEED_RELATIONSHIP_CACHE_SECONDS=300
FEED_LOGIN_RATE_LIMIT_PER_MINUTE=10
FEED_READ_RATE_LIMIT_PER_MINUTE=120
FEED_WRITE_RATE_LIMIT_PER_MINUTE=30
FEED_REQUEST_LOGGING=true

# The embedding service defaults to deterministic local hash embeddings so the
# project works without paid API keys. 
# Supported providers: hash, openai, gemini, cohere. 
EMBEDDING_PROVIDER=hash
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings
OPENAI_EMBEDDING_TIMEOUT_SECONDS=10
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/{model}:batchEmbedContents
GEMINI_EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT
GEMINI_EMBEDDING_TIMEOUT_SECONDS=10
COHERE_API_KEY=
COHERE_EMBEDDING_MODEL=embed-english-light-v3.0
COHERE_EMBEDDING_ENDPOINT=https://api.cohere.com/v2/embed
COHERE_EMBEDDING_INPUT_TYPE=search_document
COHERE_EMBEDDING_TRUNCATE=END
COHERE_EMBEDDING_TIMEOUT_SECONDS=10

EXPO_PUBLIC_API_URL=http://localhost:8000/api
EXPO_PUBLIC_AUTH_TOKEN=
