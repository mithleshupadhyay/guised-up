APP_NAME="Guised Up Feed"
APP_ENV=local
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Docker host ports. If API_HOST_PORT changes, update APP_URL and
# EXPO_PUBLIC_API_URL to the same host port.
API_HOST_PORT=8000
POSTGRES_HOST_PORT=5432
EMBEDDING_HOST_PORT=18080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=guised_up
DB_USERNAME=guised_up
DB_PASSWORD=guised_up

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:19006,127.0.0.1

FEED_EMBEDDING_DIMENSIONS=384
FEED_EMBEDDING_MODEL=hash-embedding-v1
FEED_EMBEDDING_SERVICE_URL=http://embedding:8080
FEED_EMBEDDING_SERVICE_TOKEN=local-embedding-service-token
FEED_EMBEDDING_TIMEOUT_SECONDS=3
FEED_ALLOW_HASH_EMBEDDING_FALLBACK=true

EXPO_PUBLIC_API_URL=http://localhost:8000/api
EXPO_PUBLIC_AUTH_TOKEN=
